   "source": [
    "huc_level = 12\n",
    "layer_id = {2:0, 4:1, 6:2, 8:3, 10:4, 12:5}[huc_level]\n",
    "url = f\"https://hydro.nationalmap.gov/arcgis/rest/services/wbd/MapServer/{layer_id}/query\"\n",
    "params = {\n",
    "    \"f\": \"geojson\",\n",
    "    \"geometry\": f\"{lon},{lat}\",\n",
    "    \"geometryType\": \"esriGeometryPoint\",\n",
    "    \"inSR\": \"4326\",\n",
    "    \"outFields\": \"*\",\n",
    "    \"returnGeometry\": \"true\",\n",
    "    \"outSR\": \"4326\"\n",
    "}\n",
    "data = requests.get(url, params=params, timeout=30).json()\n",
    "with open(\"basin.geojson\",\"w\") as f:\n",
    "    json.dump(data,f)\n",
    "gdf=gpd.read_file(\"basin.geojson\")\n",
    "m.add_gdf(gdf,layer_name=f\"WBD HUC{huc_level}\")\n",
    "m"
   ]
  },
